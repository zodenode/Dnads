# Required for POST /api/generate (Claude)
ANTHROPIC_API_KEY=

# Meta Ad Library (Graph API ads_archive)
META_ACCESS_TOKEN=
# Optional override, default v21.0
# META_GRAPH_VERSION=v21.0

# TikTok Commercial Content / Ad Library (client credentials)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Optional: override default field list for ad/query
# TIKTOK_ADLIB_FIELDS=ad.id,ad.first_shown_date,...

# Google Ads Transparency via SerpApi JSON engine
SERPAPI_API_KEY=

# Monitor job persistence (default ./data/)
# DATA_DIR=

# GET /api/cron/jobs — set to require ?secret= or Authorization: Bearer
# CRON_SECRET=
