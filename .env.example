# LLM for POST /api/generate (use one path)
# Option A — Anthropic Claude (preferred when set)
ANTHROPIC_API_KEY=
# Option B — NVIDIA NIM only (no Anthropic key required)
# NVIDIA_API_KEY=
# NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct

# Clerk (https://dashboard.clerk.com) — authentication + session
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Local smoke test without Clerk keys (omit publishable key or set to 1)
# NEXT_PUBLIC_CLERK_DISABLED=1

# Optional: custom URLs (defaults work for local dev)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Access tiers: set per user in Clerk Dashboard → Users → Public metadata
# e.g. { "plan": "free" } | { "plan": "pro" } | { "plan": "studio" }

# Meta Ad Library (Graph API ads_archive)
META_ACCESS_TOKEN=
# Optional override, default v21.0
# META_GRAPH_VERSION=v21.0

# TikTok Commercial Content / Ad Library (client credentials)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Optional: override default field list for ad/query
# TIKTOK_ADLIB_FIELDS=ad.id,ad.first_shown_date,...

# Google Ads Transparency via SerpApi JSON engine
SERPAPI_API_KEY=

# Monitor job persistence (default ./data/)
# DATA_DIR=

# GET /api/cron/jobs — set to require ?secret= or Authorization: Bearer
# CRON_SECRET=

# User integrations (Meta/TikTok OAuth + encrypted manual tokens) — see docs/INTEGRATIONS.md
# INTEGRATIONS_SECRET=long-random-string-for-aes-encryption
# NEXT_PUBLIC_APP_URL=https://your-host.example.com
# NEXT_PUBLIC_META_APP_ID=
# META_APP_SECRET=
# NEXT_PUBLIC_TIKTOK_CLIENT_KEY= (same as TIKTOK_CLIENT_KEY for OAuth authorize URL)

# Optional: fetch public library HTML when API rows < 4 (fragile / ToS-sensitive)
# BACKUP_HTML_FETCH=1

# --- Multimodal provider layer (optional; see docs/MULTIMODAL_PROVIDERS.md) ---

# NVIDIA NIM API catalog (build.nvidia.com) — OpenAI-compatible chat + images
# When ANTHROPIC_API_KEY is unset, NVIDIA_API_KEY drives the growth pipeline LLM.
# NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_IMAGE_MODEL=

# OpenAI-compatible speech-to-text (e.g. OpenAI Whisper API)
# ASR_OPENAI_BASE_URL=https://api.openai.com
# ASR_OPENAI_API_KEY=
# ASR_OPENAI_MODEL=whisper-1
