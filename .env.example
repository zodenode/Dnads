# Required for POST /api/generate (Claude)
ANTHROPIC_API_KEY=

# Clerk (https://dashboard.clerk.com) — authentication + session
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: custom URLs (defaults work for local dev)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Access tiers: set per user in Clerk Dashboard → Users → Public metadata
# e.g. { "plan": "free" } | { "plan": "pro" } | { "plan": "studio" }
